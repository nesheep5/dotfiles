# Ghostty Configuration（全環境共通部分）
# 環境依存の設定（font-size / window-size / keybind 等）は config.local に置く。
# config.local は .gitignore 済み。末尾の config-file で読み込む。

theme = TokyoNight

# ========================================
# フォント設定
# ※ 全環境共通。各環境に Hack Nerd Font の導入が必要
#    （未導入環境では ghostty のフォールバックフォントで表示される）
#    font-size は環境依存のため config.local 側に置く
# ========================================
font-family = Hack Nerd Font Mono

# ========================================
# ウィンドウの余白
# ※ 文字が端に密着しないように内側へ余白を設ける。balance で四辺を均等化。
#    背景の透明度・blur は環境依存のため config.local 側に置く。
# ========================================
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true

# ========================================
# split（フォーカスしていないペインを暗くする）
# ========================================
unfocused-split-opacity = 0.7

# ========================================
# シェルインテグレーション
# ========================================
shell-integration-features = true

# ========================================
# マウスサポート
# ========================================
mouse-hide-while-typing = true
copy-on-select = clipboard

# ========================================
# フォントのリガチャ（合字）を無効化
# ※ == や -> 等の合字を出さず、素のグリフで表示する。
# ========================================
font-feature = -calt
font-feature = -liga
font-feature = -dlig

# ========================================
# カーソル設定
# ========================================
cursor-style = block
cursor-style-blink = true

# ========================================
# その他の便利な設定
# ========================================
confirm-close-surface = false
clipboard-read = allow
clipboard-write = allow

# ========================================
# 環境固有設定を読み込む
# font-size / window-size / background / Mac固有 keybind は config.local へ。
#
# ghostty の config-file は「この config ファイル自身のあるディレクトリ」基準で
# 相対解決される（symlink を辿った実体＝リポジトリ側ディレクトリが基準）。
# そのため config.local はリポジトリ側の ghostty/.config/ghostty/config.local に
# 実体として置く（.gitignore 済みなのでコミットされない）。
# 先頭の "?" で optional 化し、不在でも起動エラーにならないようにする。
# ========================================
config-file = ?config.local
